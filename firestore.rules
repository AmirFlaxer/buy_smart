rules_version = '2';

// ───────────────────────── BuySmart Firestore Security Rules ─────────────────────────
// מבנה: lists/{listId} (name, ownerId, members[], inviteCode, customLocations[])
//        lists/{listId}/items/{itemId}
//        lists/{listId}/joinRequests/{uid} (uid, name) — בקשות הצטרפות ממתינות
//        users/{userId} (fcmToken)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(listData) {
      return isSignedIn() && request.auth.uid in listData.members;
    }

    match /lists/{listId} {
      // read מותר לכל מאומת — נדרש כדי לאפשר הצטרפות ע"י query לפי inviteCode
      // (קוד ההזמנה בן 6 הספרות הוא הסוד שמגן על הגישה בפועל).
      allow read: if isSignedIn();

      // יצירה: רק היוצר עצמו, חייב להיות גם הבעלים וגם חבר.
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.ownerId
                    && request.auth.uid in request.resource.data.members;

      // עדכון: רק חבר קיים (כולל אישור הצטרפות = הוספת חבר חדש ל-members).
      // אין יותר הצטרפות עצמית — הצטרפות עוברת דרך joinRequests + אישור חבר.
      allow update: if isMember(resource.data);

      allow delete: if isMember(resource.data);

      match /items/{itemId} {
        allow read, write: if isMember(
          get(/databases/$(database)/documents/lists/$(listId)).data
        );
      }

      // בקשות הצטרפות: המבקש יוצר/מבטל את שלו; חבר רואה ומאשר (מחיקה) או דוחה.
      match /joinRequests/{uid} {
        function listData() {
          return get(/databases/$(database)/documents/lists/$(listId)).data;
        }
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow read:   if request.auth.uid == uid || isMember(listData());
        allow delete: if request.auth.uid == uid || isMember(listData());
      }
    }
  }
}
