rules_version = '2';

// ───────────────────────── BuySmart Firestore Security Rules ─────────────────────────
// מבנה: lists/{listId} (name, ownerId, members[], inviteCode, customLocations[])
//        lists/{listId}/items/{itemId}
//        lists/{listId}/joinRequests/{uid} (uid, name) — בקשות הצטרפות ממתינות
//        inviteCodes/{code} (listId, name) — מיפוי קוד הזמנה → רשימה (get בלבד, ללא סריקה)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(listData) {
      return isSignedIn() && request.auth.uid in listData.members;
    }

    match /lists/{listId} {
      // read מותר רק לחברי הרשימה. ההצטרפות לפי קוד עוברת דרך inviteCodes/{code}
      // (lookup ישיר לפי מזהה, ללא יכולת לסרוק את כל הרשימות).
      allow read: if isMember(resource.data);

      // יצירה: רק היוצר עצמו, חייב להיות גם הבעלים וגם חבר.
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.ownerId
                    && request.auth.uid in request.resource.data.members;

      // עדכון: רק חבר קיים, ובהגבלות שלמות:
      //  - אסור לשנות בעלות (ownerId קבוע).
      //  - אפשר להסיר מ-members רק את עצמך (אי אפשר "לבעוט" חברים אחרים או את הבעלים).
      // הוספת חברים (אישור הצטרפות) מותרת — חברים נחשבים מהימנים ממילא.
      allow update: if isMember(resource.data)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && resource.data.members.removeAll(request.resource.data.members)
                         .hasOnly([request.auth.uid]);

      allow delete: if isMember(resource.data);

      match /items/{itemId} {
        allow read, write: if isMember(
          get(/databases/$(database)/documents/lists/$(listId)).data
        );
      }

      // בקשות הצטרפות: המבקש יוצר/מבטל את שלו; חבר רואה ומאשר (מחיקה) או דוחה.
      match /joinRequests/{uid} {
        function listData() {
          return get(/databases/$(database)/documents/lists/$(listId)).data;
        }
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow read:   if request.auth.uid == uid || isMember(listData());
        allow delete: if request.auth.uid == uid || isMember(listData());
      }
    }

    // מיפוי קוד הזמנה → רשימה. get בלבד: מי שיודע את הקוד (הסוד) יכול לתרגם אותו
    // ל-listId, אך אין list — אי אפשר לסרוק/למנות את כל הקודים.
    match /inviteCodes/{code} {
      allow get: if isSignedIn();
      // יצירה: רק חבר ברשימה שאליה הקוד ממופה (כולל הבעלים בעת יצירת הרשימה
      // ו-backfill עצלן ע"י חברים קיימים). המיפוי קבוע — ללא update/delete.
      allow create: if isSignedIn()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/lists/$(request.resource.data.listId)).data.members;
    }
  }
}
